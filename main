from funciones import ProcesadorSIATA, ProcesadorEEG


def menu():
    while True:
        print("SISTEMA DE EXPLORACIÓN NEUROAMBIENTAL")
        print("1. Procesar archivos SIATA (CSV)")
        print("2. Procesar archivos EEG (MAT)")
        print("3. Salir del programa")

        op = input("Seleccione una opción: ")

        if op == "1":
            ruta = input("\nIngrese la ruta del archivo CSV: ")
            try:
                obj = ProcesadorSIATA(ruta)
            except:
                print("Error: archivo inválido o no encontrado")
                continue

            while True:
                print("\n MENÚ SIATA")
                print("1. Mostrar información general del archivo")
                print("2. Generar gráficos estadísticos (plot, boxplot, histograma)")
                print("3. Realizar operaciones sobre columnas (apply, map, suma)")
                print("4. Realizar remuestreo temporal (diario, mensual, trimestral)")
                print("5. Volver al menú principal")

                sub = input("Seleccione una opción: ")

                if sub == "1":
                    obj.mostrar_info()
                elif sub == "2":
                    obj.graficar()
                elif sub == "3":
                    obj.operaciones()
                elif sub == "4":
                    obj.remuestreo()
                elif sub == "5":
                    break
                else:
                    print("Opción no válida.")

        elif op == "2":
            ruta = input("\nIngrese la ruta del archivo MAT: ")
            try:
                obj = ProcesadorEEG(ruta)
            except:
                print("Error: archivo inválido o no encontrado")
                continue
            obj.mostrar_llaves()

            while True:
                print("\n MENÚ EEG ")
                print("1. Sumar tres canales en un intervalo de tiempo")
                print("2. Calcular promedio y desviación estándar de la señal")
                print("3. Volver al menú principal")

                sub = input("Seleccione una opción: ")

                if sub == "1":
                    obj.operar()
                elif sub == "2":
                    obj.estadisticas()
                elif sub == "3":
                    break
                else:
                    print("Opción no válida.")

        elif op == "3":
            print("Cerrando...")
            break
        else:
            print("Opción no válida.")
            
if __name__ == "__main__":
    menu()